# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=your_mongodb_atlas_connection_string_here

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# ChromaDB
CHROMA_URL=http://localhost:8000

# Crawler
MAX_CRAWL_PAGES=25
MAX_HTML_SIZE_BYTES=5000000

# Content processing
CHUNK_SIZE_WORDS=700
CHUNK_OVERLAP_WORDS=100

# CORS — set to your deployed frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Rate limiting — auth routes (strict)
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Per-account exponential backoff (login)
AUTH_BACKOFF_BASE_MS=1000
AUTH_BACKOFF_MAX_MS=300000
AUTH_BACKOFF_RESET_AFTER_MS=3600000

# Rate limiting — public/health endpoint (loose)
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=60

# Rate limiting — authenticated actions (moderate, weighted by cost)
RATE_LIMIT_CRAWL_WINDOW_MS=900000
RATE_LIMIT_CRAWL_MAX=5

RATE_LIMIT_SEARCH_WINDOW_MS=300000
RATE_LIMIT_SEARCH_MAX=30

RATE_LIMIT_ASK_WINDOW_MS=900000
RATE_LIMIT_ASK_MAX=20
